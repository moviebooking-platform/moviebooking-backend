# Movie Ticket Booking System

# Application
NODE_ENV=development
PORT=3000

# Database (SQL Server)
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=
DB_DATABASE=moviebooking_db

# Initial Admin (for migration seeding)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@moviebooking.com
ADMIN_PASSWORD=

# JWT 
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ID Encryption
ID_ENCRYPTION_KEY=

# Service Ports
IDENTITY_SERVICE_PORT=3001
THEATRE_SERVICE_PORT=3002

# Inter-Service URLs
THEATRE_SERVICE_URL=http://localhost:3002

